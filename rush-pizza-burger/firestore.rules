rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function hasRole(roles) {
      return isSignedIn() && userRole() in roles;
    }

    function isAdmin() {
      return hasRole(['super_admin', 'admin', 'manager']);
    }

    function isStaff() {
      return hasRole(['super_admin', 'admin', 'manager', 'cashier', 'kitchen_staff', 'delivery_rider', 'employee']);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if hasRole(['super_admin', 'admin']);
    }

    match /employees/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /menu_categories/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /menu_items/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /recipes/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /inventory_items/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /suppliers/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /purchases/{id} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    match /stock_movements/{id} {
      allow read: if isStaff();
      allow create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /orders/{id} {
      allow read: if isSignedIn() && (
        isStaff() ||
        resource.data.userId == request.auth.uid
      );
      allow create: if true;
      allow update: if isStaff() || (
        isSignedIn() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
      );
      allow delete: if isAdmin();
    }

    match /tables/{id} {
      allow read: if isStaff();
      allow write: if hasRole(['super_admin', 'manager', 'cashier']);
    }

    match /payments/{id} {
      allow read: if isStaff();
      allow create: if hasRole(['super_admin', 'manager', 'cashier']);
      allow update, delete: if isAdmin();
    }

    match /expenses/{id} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /attendance/{id} {
      allow read: if isStaff();
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && resource.data.employeeId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /notifications/{id} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.role == userRole() ||
        isAdmin()
      );
      allow write: if isStaff();
    }

    match /coupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /deals/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{id} {
      allow read: if true;
      allow write: if isAdmin() || (id == 'order_sequence' && isStaff());
    }

    match /audit_logs/{id} {
      allow read: if isAdmin();
      allow create: if isStaff();
      allow update, delete: if false;
    }
  }
}
